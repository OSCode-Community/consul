# AWS S3 credentials for the bucket that is fronted by the CDN.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Public base URL that serves the bucket (no trailing slash).
# Returned URLs look like: <AWS_S3_PUBLIC_BASE_URL>/<id>.webp
AWS_S3_PUBLIC_BASE_URL=https://cdn.oscode.co.in

# Maximum accepted upload size, in MB.
MAX_UPLOAD_MB=10
